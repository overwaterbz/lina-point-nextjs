# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# n8n Integration
N8N_WEBHOOK_URL=https://overwater.app.n8n.cloud/webhook/your-workflow
N8N_SECRET=your-new-n8n-secret-here

# Payment Processing
# PRIMARY: Square (your main billing system)
# FALLBACK: Stripe (automatic if Square fails)
SQUARE_APPLICATION_ID=sq0idp-your-app-id
SQUARE_ACCESS_TOKEN=EAAA-your-access-token
NEXT_PUBLIC_SQUARE_APPLICATION_ID=sq0idp-your-app-id
SQUARE_WEBHOOK_SIGNATURE_KEY=your-square-webhook-signature-key

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+1xxxxxxxxxx

# AI Enhancement (Grok recommended)
GROK_API_KEY=gsk_your_grok_api_key
# Alternative: OpenAI
# OPENAI_API_KEY=sk-proj-your-openai-key

# OTA Price Scraping — SerpAPI (primary) + Tavily (fallback)
# Sign up at https://serpapi.com — Google Hotels endpoint gives real structured prices
SERPAPI_KEY=your-serpapi-key
TAVILY_API_KEY=tvly-your-tavily-api-key

# Music Generation (Suno AI)
SUNO_API_KEY=your-suno-api-key
SUNO_API_BASE_URL=https://api.sunoapi.org

# Email Delivery (Resend)
RESEND_API_KEY=re_your-resend-api-key
MAGIC_FROM_EMAIL=magic@linapointresort.com

# Cron Jobs & Admin
CRON_SECRET=your-generated-cron-secret
ADMIN_EMAILS=admin@example.com,owner@example.com
